{
  "name": "@repo/types",
  "version": "0.0.1",
  "description": "Shared types for the turborepo",
  "author": "Elber Gutierrez",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc"
  },
  "exports": {
    "./item.schema": {
      "types": "./src/item.schema.ts",
      "default": "./dist/item.schema.js"
    },
    "./canvasItem.schema": {
      "types": "./src/canvasItem.schema.ts",
      "default": "./dist/canvasItem.schema.js"
    }
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "typescript": "latest"
  }
}
