DATABASE_URL="postgresql://<username>:<password>@db.prisma.io:5432/<database_name>-production"
PORT=somePort
JWT_SECRET=your_generated_random_string_here
CORS_ORIGIN= dashboard_url, menu_display_url
JWT_EXPIRES_IN=some_time
NODE_ENV=development or production

R2_ENDPOINT=your_r2_endpoint_here
BUCKET_NAME=your_bucket_name_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here